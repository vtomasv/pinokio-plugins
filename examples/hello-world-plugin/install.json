{
  "run": [
    {
      "method": "shell.run",
      "params": {
        "message": "python -m venv venv",
        "path": "{{cwd}}"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "pip install -r requirements.txt",
        "path": "{{cwd}}",
        "venv": "venv"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "{{ram < 6 ? 'ollama pull llama3.2:1b' : ram < 12 ? 'ollama pull llama3.2:3b' : 'ollama pull llama3.1:8b'}}",
        "path": "{{cwd}}"
      }
    },
    {
      "method": "fs.mkdir",
      "params": {
        "path": "{{cwd}}/data"
      }
    }
  ]
}
