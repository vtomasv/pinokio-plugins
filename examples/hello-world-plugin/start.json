{
  "daemon": true,
  "run": [
    {
      "method": "shell.run",
      "params": {
        "message": "python server/app.py",
        "path": "{{cwd}}",
        "venv": "venv",
        "env": {
          "PORT": "{{port}}",
          "DATA_DIR": "{{cwd}}/data",
          "OLLAMA_URL": "http://localhost:11434"
        }
      }
    },
    {
      "method": "browser.open",
      "params": {
        "url": "http://localhost:{{port}}"
      }
    }
  ]
}
